node_modules
dist
.DS_Store
*.local
.vite

# Cloudflare local dev secrets/vars — never commit
.dev.vars

# Local Wrangler state (D1 shadow / persistence) — never commit
.wrangler

# Local agent/editor session state — never commit
.claude

# Tribute audio master — ship only the compressed .m4a the player uses, never the raw .wav
public/tribute/**/*.wav

# Voice Notes Studio — keep the folder + code, but never commit recordings/media
public/production-studio/voice-notes/audio/*
public/production-studio/voice-notes/images/*
!public/production-studio/voice-notes/audio/.gitkeep
!public/production-studio/voice-notes/images/.gitkeep

# TK Tribute — keep the archival WAV master local; never commit (Cloudflare 25 MiB cap)
public/tribute/tk/*.wav
