# Tribute audio master — ship only the compressed .m4a the player uses, never the raw .wav
public/tribute/**/*.wav

# Audio Studio — keep the folder + code, but never commit recordings/media
private-voice-notes-studio/audio/*
private-voice-notes-studio/images/*
!private-voice-notes-studio/audio/.gitkeep
!private-voice-notes-studio/images/.gitkeep

# TK Tribute — keep the archival WAV master local; never commit (Cloudflare 25 MiB cap)
public/tribute/tk/*.wav
