# Cloudflare Pages routing rules (served from dist root)

# The TK Tribute is a real page at /tribute/tk (built to /tribute/tk/index.html),
# so no rewrite is needed to render it. These rules only canonicalize the aliases.

# Raw filename -> clean tribute URL.
/tk-tribute.html    /tribute/tk    301

# Hyphen alias -> clean tribute URL.
/tribute-tk         /tribute/tk    301
